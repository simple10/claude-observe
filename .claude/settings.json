{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "AGENTS_OBSERVE_PROJECT_SLUG": "agents-observe",
    "AGENTS_OBSERVE_LOG_LEVEL": "trace",
    "AGENTS_OBSERVE_SHUTDOWN_DELAY_MS": "30000",
    "AGENTS_OBSERVE_NOTIFICATION_ON_EVENTS": "Stop,Notification"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/hooks/scripts/hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/hooks/scripts/hook.sh"
